{
  "name": "tlcsdm-vscode-git-blame-info",
  "displayName": "Tlcsdm Git Blame Info",
  "description": "Display git blame information in the editor gutter with color-coded annotations, inspired by Eclipse EGit",
  "version": "1.0.1",
  "publisher": "unknowIfGuestInDream",
  "icon": "images/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tlcsdm/vscode-git-blame-info"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "SCM Providers"
  ],
  "keywords": [
    "git",
    "blame",
    "annotation",
    "revision",
    "egit"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "tlcsdm-gitBlameInfo.showRevisionInformation",
        "title": "Show Revision Information",
        "category": "Tlcsdm Git Blame Info"
      },
      {
        "command": "tlcsdm-gitBlameInfo.hideRevisionInformation",
        "title": "Hide Revision Information",
        "category": "Tlcsdm Git Blame Info"
      },
      {
        "command": "tlcsdm-gitBlameInfo.openCommit",
        "title": "Open Commit",
        "category": "Tlcsdm Git Blame Info"
      },
      {
        "command": "tlcsdm-gitBlameInfo.openHistory",
        "title": "Open History",
        "category": "Tlcsdm Git Blame Info"
      },
      {
        "command": "tlcsdm-gitBlameInfo.openSettings",
        "title": "Open Settings",
        "category": "Tlcsdm Git Blame Info"
      },
      {
        "command": "tlcsdm-gitBlameInfo.copyCommitId",
        "title": "Copy Commit ID",
        "category": "Tlcsdm Git Blame Info"
      }
    ],
    "menus": {
      "editor/lineNumber/context": [
        {
          "command": "tlcsdm-gitBlameInfo.showRevisionInformation",
          "when": "!tlcsdm-gitBlameInfo.isActive",
          "group": "1_modification"
        },
        {
          "command": "tlcsdm-gitBlameInfo.hideRevisionInformation",
          "when": "tlcsdm-gitBlameInfo.isActive",
          "group": "1_modification"
        }
      ]
    },
    "configuration": {
      "title": "Tlcsdm Git Blame Info",
      "properties": {
        "tlcsdm-gitBlameInfo.showAuthor": {
          "type": "boolean",
          "default": true,
          "description": "Show author name in the gutter annotation"
        },
        "tlcsdm-gitBlameInfo.showDate": {
          "type": "boolean",
          "default": true,
          "description": "Show commit date in the gutter annotation"
        },
        "tlcsdm-gitBlameInfo.showCommitId": {
          "type": "boolean",
          "default": false,
          "description": "Show abbreviated commit ID in the gutter annotation"
        },
        "tlcsdm-gitBlameInfo.showSummary": {
          "type": "boolean",
          "default": true,
          "description": "Show commit summary (message) in the gutter annotation"
        },
        "tlcsdm-gitBlameInfo.useRelativeDate": {
          "type": "boolean",
          "default": false,
          "description": "Show relative dates (e.g. '2 months ago') instead of formatted dates in the gutter annotation"
        },
        "tlcsdm-gitBlameInfo.dateFormat": {
          "type": "string",
          "default": "YYYY-MM-DD",
          "description": "Date format for the gutter annotation"
        },
        "tlcsdm-gitBlameInfo.columnWidth": {
          "type": "number",
          "default": 50,
          "minimum": 20,
          "maximum": 100,
          "description": "Width of the blame annotation column in characters"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test --config ./.vscode-test.json"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.85.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.4.1",
    "@vscode/vsce": "^3.2.2",
    "eslint": "^10.1.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.58.0"
  }
}
